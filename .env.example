# Z-ZERO MCP Server: Environment Variables Template

# --- UNIFIED API ACCESS ---
# The base URL of your deployed Z-ZERO Dashboard
Z_ZERO_API_BASE_URL=https://clawcard.store

# Your Passport API Key (obtianed from Dashboard > Admin > Agents)
# This key allows the bot to check balance and issue tokens.
Z_ZERO_API_KEY=zk_...your_secret_passport_key

# --- SUPABASE (Optional - for legacy tools) ---
Z_ZERO_SUPABASE_URL=your_supabase_project_url
Z_ZERO_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# --- AIRWALLEX (Optional - for legacy tools) ---
Z_ZERO_AIRWALLEX_API_KEY=your_airwallex_api_key
Z_ZERO_AIRWALLEX_CLIENT_ID=your_airwallex_client_id
Z_ZERO_AIRWALLEX_ENV=demo # or 'prod'
